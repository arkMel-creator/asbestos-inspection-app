# Asbestos Inspection Management System - Backend Configuration
# Copy this file to .env and customize for your environment

# Server Port
PORT=3000

# JWT Secret - Change this to a random string in production!
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production

# Default Admin User Credentials - Change in production!
ADMIN_USER=admin
ADMIN_PASS=admin123

# Database Location (relative to server directory)
# Database file will be created automatically if it doesn't exist
# DB_PATH=./data.sqlite

# Node Environment
NODE_ENV=development
